    "filenames = [path.as_posix() for path in path_to_tf_records.glob(\"train/*.tfrecords\")]\n",
    "\n",
    "fn = os.path.join(os.path.dirname(filenames[0]), 'config_bytes_description.pkl')\n",
    "with open(fn, 'rb') as f:\n",
    "    bytes_description = pickle.load(f)\n",
    "\n",
    "fn = os.path.join(os.path.dirname(filenames[0]), 'config_feature_description.pkl')\n",
    "with open(fn, 'rb') as f:\n",
    "    feature_description = pickle.load(f)\n",
    "\n",
    "\n",
    "dataset = util_tfrecords.get_dataset_from_tfrecords(\n",
    "    filenames,\n",
    "    feature_description='config_feature_description.pkl',\n",
    "    features_to_exclude=['list_'],\n",
    "    bytes_description='config_bytes_description.pkl',\n",
    "    compression_type='GZIP',\n",
    "    eval_mode=False,\n",
    "    buffer_size_prefetch=tf.data.AUTOTUNE,\n",
    "    buffer_size_shuffle=1024,\n",
    "    batch_size=2,\n",
    "    shuffle_seed=None,\n",
    "    densify_downsample_factors=None,\n",
    "    densify_jitter_indices=None,\n",
    "    densify_dtype=tf.float32,\n",
    "    filter_function=None,\n",
    "    map_function=None,\n",
    "    verbose=True)\n",
    "\n",
    "for example in iter(dataset):\n",
    "    break\n",
    "\n",
    "for k in example.keys():\n",
    "    example[k] = example[k].numpy()\n",
    "    print(k, example[k].shape, example[k].dtype)\n",
    "\n",
    "for itr0 in range(example['sr'].shape[0]):\n",
    "    rate = example['sr'][itr0]\n",
    "    data = example['signal'][itr0].T\n",
